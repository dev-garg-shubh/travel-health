{
  "name": "travel-health",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "turbo run dev --filter=@travel-health/web --filter=@travel-health/ui",
    "dev:backend": "turbo run dev --filter=@travel-health/api-gateway --filter=@travel-health/travel-service --filter=@travel-health/health-service --filter=@travel-health/data-scraper-service --filter=@travel-health/data-analyzer-service --filter=@travel-health/score-api-service",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@travel-health/web --filter=@travel-health/ui",
    "build:backend": "turbo run build --filter=@travel-health/api-gateway --filter=@travel-health/travel-service --filter=@travel-health/health-service --filter=@travel-health/data-scraper-service --filter=@travel-health/data-analyzer-service --filter=@travel-health/score-api-service",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.0.14",
    "typescript": "^5.8.3"
  }
}
